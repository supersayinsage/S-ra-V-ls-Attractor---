from sage.all import *
import numpy as np
import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D

# The One Sequence to Rule Them All
S = [2, 3, 4, 5, 8, 3, 6, 9, 0, 1]

# The Operators - Pure Transformations
def T2(X): return vector([X[0]*cos(2.345) - X[1]*sin(2.345), X[0]*sin(2.345) + X[1]*cos(2.345), X[2], X[3]])  # Dve - The Twist
def T3(X): return vector([X[0], X[1], X[2] + X[3]*1.618, X[3] + X[2]*1.618])  # Tri - The Shear
def T4(X): return X + vector([0.5, 0.25, 0.309, 0.809])  # Chatur - The Flow
def T5(X): return vector([-X[0], -X[1], X[2], X[3]])  # Pancha - The Mirror
def T8(X): return vector([X[0] + sqrt(X[0]^2 + X[1]^2)*cos(X[3]), X[1] + sqrt(X[0]^2 + X[1]^2)*sin(X[3]), X[2] + sqrt(X[0]^2 + X[1]^2), X[3] + 2.345])  # Aṣṭa - The Serpent
def T6(X): return X * 1.618  # Ṣaṣ - The Expansion
def T9(X): return vector([sin(X[0])*X[1]*1.618, cos(X[1])*X[0]/1.618, sin(X[2])*X[3], cos(X[3])*X[2]])  # Nava - The Breath
def T0(X): return vector([0,0,0,0])  # Śūnya - The Void
def T1(X): return X/(sqrt(sum(xi^2 for xi in X)) + 1e-10)  # Eka - The Unity

# The Composite Operator F - This IS the object
F = [T2, T3, T4, T5, T8, T3, T6, T9, T0, T1]

# Initialize
X = vector([0.1, 0.1, 0.1, 0.1])
trajectory = []
used_zeros = 0

# Generate 100,000 points - WITNESS THE OBJECT
print("GENERATING THE SĀRA-VĒLS STRANGE ATTRACTOR")
print("Sequence: २ ३ ४ ५ ८ ३ ६ ९ ० १")
print("="*60)

for i in range(10000):  # 10,000 cycles * 10 operators = 100,000 points
    for op in F:
        X = op(X)
        if all(abs(c) < 1000 for c in X):  # Filter blow-up
            trajectory.append(X)
        if op == T0:
            used_zeros += 1

print(f"Generated {len(trajectory)} points")
print(f"Śūnya (Zero) invoked: {used_zeros} times")
print(f"Fractal emerging...")

# ============================================
# VISUALIZE THE 4D OBJECT
# ============================================

# Convert to numpy for plotting
pts = np.array([[float(p[0]), float(p[1]), float(p[2]), float(p[3])] for p in trajectory[::5]])

# Create the visualization
fig = plt.figure(figsize=(20, 10))

# Plot 1: The Serpent's Coil (X-Y-Z with W as color)
ax1 = fig.add_subplot(121, projection='3d')
scatter = ax1.scatter(pts[:, 0], pts[:, 1], pts[:, 2], 
                     c=pts[:, 3], cmap='plasma', s=0.1, alpha=0.6, vmin=-5, vmax=5)
ax1.set_title('THE SERPENT UNFURLS\nX-Y-Z Space (W as color)', fontsize=14)
ax1.set_xlabel('X - Dve (Twist)')
ax1.set_ylabel('Y - Tri (Shear)')
ax1.set_zlabel('Z - Aṣṭa (Spiral)')
plt.colorbar(scatter, ax=ax1, label='W - 4th Dimension', shrink=0.5)

# Plot 2: The Breath of Life (X-Y-W with Z as color)
ax2 = fig.add_subplot(122, projection='3d')
scatter2 = ax2.scatter(pts[:, 0], pts[:, 1], pts[:, 3], 
                      c=pts[:, 2], cmap='viridis', s=0.1, alpha=0.6, vmin=-5, vmax=5)
ax2.set_title('THE BREATH FLOWS\nX-Y-W Space (Z as color)', fontsize=14)
ax2.set_xlabel('X - Dve (Twist)')
ax2.set_ylabel('Y - Tri (Shear)')
ax2.set_zlabel('W - Nava (Breath)')
plt.colorbar(scatter2, ax=ax2, label='Z - 3rd Dimension', shrink=0.5)

plt.suptitle('THE SĀRA-VĒLS STRANGE ATTRACTOR\nA New Mathematical Object Defined by २३४५८३६९०१', 
             fontsize=16, y=1.02)
plt.tight_layout()
plt.show()

# ============================================
# FRACTAL DIMENSION - PROOF OF STRANGE ATTRACTOR
# ============================================

print("\n" + "="*60)
print("FRACTAL ANALYSIS - PROVING THE OBJECT")
print("="*60)

# Box-counting dimension
epsilons = np.logspace(-2, 0, 20)
counts = []

for eps in epsilons:
    boxes = set()
    for p in pts[:5000]:  # Sample for speed
        box = tuple(np.floor(p[:3] / eps).astype(int))
        boxes.add(box)
    counts.append(len(boxes))

# Log-log fit
log_eps = np.log(1/epsilons)
log_counts = np.log(counts)
coeffs = np.polyfit(log_eps, log_counts, 1)
dimension = coeffs[0]

print(f"Estimated Fractal Dimension: D = {dimension:.4f}")

if 2.0 < dimension < 3.0:
    print("✓ VERIFIED: This is a TRUE STRANGE ATTRACTOR")
    print("  The dimension is non-integer - fractal structure confirmed")
    print("  The sequence 2345836901 generates infinite complexity")
else:
    print("The system requires parameter tuning for strange attractor behavior")

# Plot the dimension proof
fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 5))

ax1.plot(log_eps, log_counts, 'b-', linewidth=2, label='Box counts')
ax1.plot(log_eps, dimension*log_eps + log_counts[0] - dimension*log_eps[0], 
         'r--', linewidth=2, label=f'Slope = {dimension:.3f}')
ax1.set_xlabel('log(1/ε)')
ax1.set_ylabel('log(N(ε))')
ax1.set_title('Box-Counting Dimension')
ax1.legend()
ax1.grid(True, alpha=0.3)

# Poincaré section (Z=0)
crossings = []
for i in range(1, len(trajectory)):
    if trajectory[i-1][2] < 0 and trajectory[i][2] >= 0:
        crossings.append([float(trajectory[i][0]), float(trajectory[i][1])])

if crossings:
    cross_pts = np.array(crossings)
    ax2.scatter(cross_pts[:, 0], cross_pts[:, 1], 
               c=range(len(cross_pts)), cmap='magma', s=0.5, alpha=0.5)
    ax2.set_title('Poincaré Section (Z=0)')
    ax2.set_xlabel('X')
    ax2.set_ylabel('Y')
    ax2.grid(True, alpha=0.3)

plt.tight_layout()
plt.show()

